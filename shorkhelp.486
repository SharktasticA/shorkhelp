#!/bin/sh

######################################################
##            SHORK UTILITY - SHORKHELP             ##
######################################################
## A utility for SHORK 486 that informs about its   ##
## capabilities and provides guidance               ##
######################################################
## Licence: GNU GENERAL PUBLIC LICENSE Version 3    ##
######################################################
## Kali (sharktastica.co.uk)                        ##
######################################################



. "$(dirname -- "$0")/shorkcommon.sh"

DROPBEAR_PRESENT=true
FILE_PRESENT=true
EMACS_PRESENT=true
GCC_PRESENT=true
GIT_PRESENT=true
LSUSB_PRESENT=true
NANO_PRESENT=true
NETWORKING_PRESENT=true
SHORKMAP_PRESENT=true
SHORKRES_PRESENT=true
TCC_PRESENT=true
TNFTP_PRESENT=true

if [ ! -x /usr/bin/scp ]; then
    DROPBEAR_PRESENT=false
fi
if [ ! -x /usr/bin/ssh ]; then
    DROPBEAR_PRESENT=false
fi
if [ ! -x /usr/bin/file ]; then
    FILE_PRESENT=false
fi
if [ ! -x /usr/bin/mg ]; then
    EMACS_PRESENT=false
fi
if [ ! -d /opt/i486-linux-musl-native ]; then
    GCC_PRESENT=false
fi
if [ ! -x /usr/bin/git ]; then
    GIT_PRESENT=false
fi
if [ ! -x /usr/bin/lsusb ]; then
    LSUSB_PRESENT=false
fi
if [ ! -x /usr/bin/nano ]; then
    NANO_PRESENT=false
fi
if [ ! -L /sbin/ip ]; then
    NETWORKING_PRESENT=false
fi
if [ ! -x /usr/bin/shorkmap ]; then
    SHORKMAP_PRESENT=false
fi
if [ ! -x /usr/bin/shorkres ]; then
    SHORKRES_PRESENT=false
fi
if [ ! -x /usr/local/bin/i386-tcc ]; then
    TCC_PRESENT=false
fi
if [ ! -x /usr/bin/ftp ]; then
    TNFTP_PRESENT=false
fi

get_term_size



print_commands()
{
    OUTPUT="\033[%smGeneral\033[%sm
ar, arch, awk, basename, bc, cat, chmod, chown, chroot, cp, cut, dc, dirname, expand, expr, false, file, find, fold, grep, gzip, head, less, ln, loadkmap, ls, man, mkdir, mknod, mount, mv, paste, printf, pwd, readlink, rev, rm, rmdir, sed, seq, showkey, stat, sync, tar, tee, test, touch, tr, true, truncate, unexpand, umount, unzip, usleep, wc, whereis, which, xz, yes

\033[%smEditors & development tools\033[%sm
as, ed, emacs, g++, gcc, git, gfortran, nano, tcc, vi

\033[%smSystem & processes\033[%sm
beep, blkid, clear, crontab, date, dd, df, dmesg, free, halt, hostname, kill, losetup, lsblk, lspci, lsusb, mdev, nice, nohup, nproc, pkill, pstree, sleep, strace, stty, swapoff, swapon, top, uname, whoami

\033[%smNetworking & remote access\033[%sm
ftp, ftpget, ftpput, ip, ifconfig, ping, route, scp, ssh, telnet, traceroute, udhcpc, wget, whois"

    if ! $DROPBEAR_PRESENT; then
       OUTPUT=$(echo "$OUTPUT" |  sed -e "s|, scp, ssh||g")
    fi
    if ! $FILE_PRESENT; then
       OUTPUT=$(echo "$OUTPUT" |  sed -e "s|, file||g")
    fi
    if ! $GCC_PRESENT; then
       OUTPUT=$(echo "$OUTPUT" |  sed -e "s|as, ||g")
       OUTPUT=$(echo "$OUTPUT" |  sed -e "s|, g++, gcc||g")
       OUTPUT=$(echo "$OUTPUT" |  sed -e "s|gfortran, ||g")
    fi
    if ! $EMACS_PRESENT; then
        OUTPUT=$(echo "$OUTPUT" | sed -e "s|, emacs||g")
    fi
    if ! $GIT_PRESENT; then
        OUTPUT=$(echo "$OUTPUT" | sed -e "s|, git||g")
    fi
    if ! $LSUSB_PRESENT; then
        OUTPUT=$(echo "$OUTPUT" | sed -e "s|lsusb, ||g")
    fi
    if ! $NETWORKING_PRESENT; then
        OUTPUT=$(echo "$OUTPUT" | sed '$d' | sed '$d' | sed '$d' | sed '$d')
    fi
    if ! $NANO_PRESENT; then
        OUTPUT=$(echo "$OUTPUT" | sed -e "s|, nano||g")
    fi
    if ! $TCC_PRESENT; then
       OUTPUT=$(echo "$OUTPUT" |  sed -e "s|tcc, ||g")
    fi
    if ! $TNFTP_PRESENT; then
        OUTPUT=$(echo "$OUTPUT" | sed -e "s|ftp, ||g")
    fi

    printf "$OUTPUT\n\033[%sm" $CYAN_BRIGHT $WHITE $CYAN_BRIGHT $WHITE $CYAN_BRIGHT $WHITE $CYAN_BRIGHT $WHITE $RESET | fold -s -w "$TERM_WIDTH"
}

print_emacs_hints()
{
    printf "\033[%smEmacs (Mg) cheatsheet\033[%sm\n\n" $CYAN_BRIGHT $WHITE

    printf "\033[%smC\033[%sm = Ctrl                           \033[%smM\033[%sm = Alt\n\n" $RED $WHITE $RED $WHITE | fold -s -w "$TERM_WIDTH" | fold -s -w "$TERM_WIDTH"

    printf "\033[%smExit:\033[%sm                   C-x C-c    \033[%smOpen file/new buffer:\033[%sm      C-x C-f\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"
    printf "\033[%smSave current buffer:\033[%sm    C-x C-s    \033[%smSave all buffers:\033[%sm          C-x s\n\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"

    printf "\033[%smSplit window:\033[%sm           C-x 2      \033[%smEnlarge window:\033[%sm            C-x ^\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"
    printf "\033[%smSwitch windows:\033[%sm         C-x o      \033[%smClose current window:\033[%sm      C-x 0\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"
    printf "\033[%smClose other windows:\033[%sm    C-x 1\n\n" $GREEN $WHITE | fold -s -w "$TERM_WIDTH"

    printf "\033[%smGo to line:\033[%sm             C-x g      \033[%smUndo:\033[%sm                      C-_\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"
    printf "\033[%smSearch (forwards):\033[%sm      C-s        \033[%smSearch (backwards):\033[%sm        C-r\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"
    printf "\033[%smFind and replace:\033[%sm       M-%%        \033[%smReformat (fit to line):\033[%sm    M-q\n" $GREEN $WHITE $GREEN $WHITE | fold -s -w "$TERM_WIDTH"

    printf "\033[%sm" $RESET
}

print_git_commands()
{
    OUTPUT="\033[%smSupported Git commands\033[%sm

add, blame, branch, checkout, cherry-pick, clean, clone, commit, config, diff, fetch, init, log, merge, mv, pull, push, rebase, reflog, remote, reset, restore, rm, show, stash, status, switch, tag"

    printf "$OUTPUT\n\033[%sm" $CYAN_BRIGHT $WHITE $RESET | fold -s -w "$TERM_WIDTH"
}

print_intro()
{
    OUTPUT="\033[%smWhat is SHORK 486?\033[%sm
SHORK 486 is a minimal Linux distribution for 486 and Pentium (P5) PCs! It focuses on being as lean and small as possible, whilst still providing a robust command and utilities set, and including hand-picked modern and custom bundled software. The goal is to provide an alternative use for old PCs, hopefully saving one or two of them from landfills.

\033[%smGetting started
\033[%sm1.\033[%sm Set your keyboard's layout with shorkmap.
\033[%sm2.\033[%sm Pick a font colour for terminal text with shorkcol.
\033[%sm3.\033[%sm (If compatible) Change your display's resolution with shorkres. A reboot is required afterwards.
\033[%sm4.\033[%sm Set your computer's name by editing /etc/hostname. A reboot is required afterwards, or you can run:
      hostname "$(cat /etc/hostname)"
\033[%sm5.\033[%sm (If applicable) Test your network connection with ping. For example:
      ping sharktastica.co.uk
\033[%sm6.\033[%sm Run shorkfetch to see a quick overview of your system and environment.
\033[%sm7.\033[%sm Check shorkhelp's other options to learn about all available commands and how to use specific utilities.
\033[%sm8.\033[%sm When you are finished using SHORK 486, run shorkoff to safely bring your system to a halt before powering off."

    printf "$OUTPUT\n\033[%sm" $CYAN_BRIGHT $WHITE $CYAN_BRIGHT $GREEN $WHITE $GREEN $WHITE $GREEN $WHITE $GREEN $WHITE $GREEN $WHITE $GREEN $WHITE $GREEN $WHITE $GREEN $WHITE $RESET | fold -s -w "$TERM_WIDTH"
}

print_utilities()
{
    printf "\033[%smSHORK Utilities\033[%sm\n" $CYAN_BRIGHT $WHITE
    
    printf "\n\033[%smshorkcol:\033[%sm Changes the terminal's foreground (text) colour. Takes one argument (a colour name); no arguments show a list of possible colours.\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"

    printf "\n\033[%smshorkdir:\033[%sm Terminal-based file browser and file inspector (if file is installed).\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"

    printf "\n\033[%smshorkfetch:\033[%sm Displays basic system and environment information. Similar to fastfetch, neofetch, etc.\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"

    printf "\n\033[%smshorkhelp:\033[%sm Provides help with using SHORK 486 via command lists, guides and cheatsheets. Requires the use of one of five parameters.\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"

    if $SHORKMAP_PRESENT; then
        printf "\n\033[%smshorkmap:\033[%sm Changes the system's keyboard map. Takes takes one argument (a keymap name); no arguments show a list of possible keymaps.\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"
    fi

    printf "\n\033[%smshorkoff:\033[%sm Brings the system to a halt and syncs the write cache, allowing the computer to be safely turned off. Similar to poweroff or shutdown -h.\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"

    if $SHORKRES_PRESENT; then
        printf "\n\033[%smshorkres:\033[%sm Changes the system's display resolution (provided hardware is compatible). Takes one argument (a resolution name); no arguments show a list of possible resolution names.\n" $GREEN_BRIGHT $WHITE | fold -s -w "$TERM_WIDTH"
    fi

    printf "\033[%sm" $RESET
}

for arg in "$@"; do
    case "$arg" in
        --commands)
            clear
            print_commands
            return 1
            ;;
        --emacs)
            if $EMACS_PRESENT; then
                clear
                print_emacs_hints
                return 1
            fi
            ;;
        --git)
            if $GIT_PRESENT; then
                clear
                print_git_commands
                return 1
            fi
            ;;
        --intro)
            clear
            print_intro
            return 1
            ;;
        --shorkutils)
            clear
            print_utilities
            return 1
            ;;
    esac
done

CMDS="--commands | --emacs | --git | --intro | --shorkutils"

if ! $EMACS_PRESENT; then
    CMDS=$(echo "$CMDS" | sed -E 's/--emacs \| //g; s/ \| --emacs//g; s/--emacs//g')
fi
if ! $GIT_PRESENT; then
    CMDS=$(echo "$CMDS" | sed -E 's/--git \| //g; s/ \| --git//g; s/--git//g')
fi

printf "Displays help and reference information for using SHORK 486 and its built-in tools.\n\n" | fold -s -w "$TERM_WIDTH"
echo "Usage: shorkhelp {$CMDS}" | fold -s -w "$TERM_WIDTH"

exit 1
